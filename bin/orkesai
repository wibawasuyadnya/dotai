#!/usr/bin/env bash
# OrkesAI launcher for npm-global installs (`npm install -g wibawasuyadnya/orkesai`).
# First run bootstraps ~/.config/orkesai from the npm package copy via
# install.sh, then every run just launches the agent.
#
#   orkesai            interactive chat
#   orkesai <question> one-shot question
#   orkesai update     re-run the installer (pull the latest code)
set -euo pipefail

DIR="$HOME/.config/orkesai"
PKG="$(cd "$(dirname "$(readlink "$0" || echo "$0")")/.." && pwd)"

if [ "${1:-}" = "update" ]; then
    bash "$PKG/install.sh"
    exit 0
fi

if [ ! -f "$DIR/ai-agent.py" ]; then
    bash "$PKG/install.sh" --local "$PKG"
fi

exec python3 "$DIR/ai-agent.py" --talk "$@"
