{
  "name": "dotai-gui",
  "version": "0.1.0",
  "private": true,
  "description": "DotAI multi-agent web GUI (Next.js) + Electron shell",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron": "electron .",
    "app": "concurrently -k \"next dev\" \"wait-on http://127.0.0.1:3000 && electron .\""
  },
  "dependencies": {
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.0",
    "electron": "^37.10.3",
    "typescript": "^5.8.0",
    "wait-on": "^8.0.0"
  },
  "allowScripts": {
    "electron@37.10.3": true
  }
}
