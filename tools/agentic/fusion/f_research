class InlineSpinner:
    """Lightweight, thread-safe single-line terminal spinner."""
    def __init__(self, msg):
        self.msg = msg
        self.active = False
        self.thread = None
        self.chars = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
        
    def _spin(self):
        idx = 0
        while self.active:
            sys.stderr.write(f"\r\033[1;36m{self.chars[idx % 10]}\033[0m {self.msg}...")
            sys.stderr.flush()
            idx += 1
            time.sleep(0.08)
            
    def start(self):
        self.active = True
        self.thread = threading.Thread(target=self._spin, daemon=True)
        self.thread.start()
        
    def stop(self, success=True):
        self.active = False
        if self.thread:
            self.thread.join()
        status = "\033[1;32m✓\033[0m" if success else "\033[1;31m✗\033[0m"
        sys.stderr.write(f"\r\x1b[2K\r{status} {self.msg}\n")
        sys.stderr.flush()


def query_model(url, headers, model_name, temp, prompt, retries=2):
    """Hits API endpoints with parameter fallbacks and OpenRouter cloud failover arrays."""
    is_openrouter = "openrouter.ai" in url
    
    payload = {}
    if is_openrouter:
        # Fall back to OpenRouter's serverside free model switcher if the primary fails
        payload["models"] = [model_name, "openrouter/free"]
    else:
        payload["model"] = model_name

    payload["temperature"] = temp
    payload["messages"] = [{"role": "user", "content": prompt}]
    
    for attempt in range(retries + 1):
        try:
            req = urlreq.Request(url, data=json.dumps(payload).encode("utf-8"), headers=headers, method="POST")
            with urlreq.urlopen(req, timeout=45) as response:
                data = json.loads(response.read().decode("utf-8"))
                if "choices" in data and len(data["choices"]) > 0:
                    return data["choices"][0]["message"]["content"]
                elif "error" in data:
                    err_msg = data["error"].get("message", "API Error")
                    if "rate limit" in err_msg.lower() and attempt < retries:
                        time.sleep(2.0 * (attempt + 1))
                        continue
                    return f"[API ERROR] {model_name}: {err_msg}"
        except urlerr.HTTPError as e:
            # Fallback: pop temperature if a restricted endpoint returns an HTTP 400 Bad Request
            if e.code == 400 and "temperature" in payload:
                payload.pop("temperature", None)
                continue
            if e.code == 429 and attempt < retries:
                time.sleep(2.0 * (attempt + 1))
                continue
            return f"[HTTP ERROR {e.code}] {model_name}"
        except Exception as e:
            if attempt < retries:
                time.sleep(2.0 * (attempt + 1))
                continue
            return f"[CONNECTION ERROR] {model_name}: {e}"
    return f"[ERROR] {model_name} failed after retries."


def execute_synthesis(prompt, reports_markdown):
    """Executes synthesis strictly on native Google API, with robust 3.1 Flash-Lite fallback."""
    judge_prompt = DRACO_JUDGE_TEMPLATE.format(
        user_prompt=prompt,
        specialist_reports=reports_markdown
    )
    
    gemini_key = os.environ.get("GEMINI_API_KEY")
    if not gemini_key:
        sys.stderr.write("\033[1;31m[CRITICAL ERROR] GEMINI_API_KEY is missing for Judge synthesis.\033[0m\n")
        return "[SYSTEM ERROR] Synthesis aborted. Please configure GEMINI_API_KEY."
        
    url = "https://generativelanguage.googleapis.com/v1beta/openai/chat/completions"
    headers = {"Content-Type": "application/json", "Authorization": f"Bearer {gemini_key}"}
    
    # 1. Attempt Primary: Gemini 3.5 Flash
    primary_model = os.environ.get("GEMINI_MODEL", "gemini-3.5-flash")
    sys.stderr.write(f"\033[90m[sys] Synthesizing via native Gemini API ({primary_model})...\033[0m\n")
    
    result = query_model(url, headers, primary_model, 0.1, judge_prompt)
    if result and not (result.startswith("[ERROR]") or result.startswith("[HTTP ERROR") or result.startswith("[CONNECTION ERROR]")):
        return result
        
    # 2. Attempt Fallback: Gemini 3.1 Flash-Lite on native Google API
    fallback_model = "gemini-3.1-flash-lite"
    sys.stderr.write(f"\033[1;33m[Warning] {primary_model} failed ({result.strip()}). Falling back to {fallback_model}...\033[0m\n")
    
    return query_model(url, headers, fallback_model, 0.1, judge_prompt)


def run_research_engine(mode, prompt):
    if mode not in FREE_PANELS:
        sys.stderr.write(f"\033[1;31mError: Mode '{mode}' not found. Select 'coder' or 'research'.\033[0m\n")
        sys.exit(1)
        
    openrouter_key = os.environ.get("OPENROUTER_API_KEY")
    if not openrouter_key:
        sys.stderr.write("\033[1;31mError: OPENROUTER_API_KEY not configured.\033[0m\n")
        sys.exit(1)
        
    panel = FREE_PANELS[mode]
    headers = {
        "Content-Type": "application/json",
        "Authorization": f"Bearer {openrouter_key}",
        "HTTP-Referer": "https://github.com/suyadnya/orkesai"
    }
    url = "https://openrouter.ai/api/v1/chat/completions"
    
    sys.stderr.write(f"\033[1;34mLaunching Fusion-Research [{mode.upper()} Mode]\033[0m\n")
    sys.stderr.write(f"\033[90mObjective: {prompt}\033[0m\n\n")
    
    # --- PHASE 1: Parallel Specialists Dispatch ---
    start_time = time.time()
    loader = InlineSpinner(f"Dispatching {len(panel)} parallel models (including Self-Fusion paths)")
    loader.start()
    
    results = {}
    with concurrent.futures.ThreadPoolExecutor(max_workers=len(panel)) as executor:
        futures = {
            executor.submit(query_model, url, headers, model, temp, prompt): f"{model} (Temp: {temp})"
            for model, temp in panel
        }
        for future in concurrent.futures.as_completed(futures):
            identifier = futures[future]
            try:
                data = future.result()
                results[identifier] = data
            except Exception as e:
                results[identifier] = f"[EXCEPTION] {e}"
                
    elapsed_specialists = time.time() - start_time
    loader.stop()
    sys.stderr.write(f"   \033[90mCompleted in {elapsed_specialists:.1f}s\033[0m\n\n")
    
    # --- PHASE 2: Local Logging ---
    log_loader = InlineSpinner("Preserving specialist reports to local audit logs")
    log_loader.start()
    
    reports_markdown = []
    for identifier, content in results.items():
        reports_markdown.append(f"### Specialist: {identifier}\n\n````\n{content}\n````\n")
    all_reports = "\n".join(reports_markdown)
    
    timestamp = time.strftime("%Y%m%d_%H%M%S")
    log_filepath = os.path.join(LOGS_DIR, f"fusion_research_{mode}_{timestamp}.md")
    
    log_content = f"""# Fusion-Research Audit Log
- **Mode:** {mode}
- **Timestamp:** {time.strftime('%Y-%m-%d %H:%M:%S')}
- **Objective:** {prompt}

---

## Specialist Reports

{all_reports}
"""
    try:
        with open(log_filepath, "w", encoding="utf-8") as f:
            f.write(log_content)
        log_loader.stop()
        sys.stderr.write(f"   \033[90mAudit log: {log_filepath}\033[0m\n\n")
    except Exception as e:
        log_loader.stop(success=False)
        sys.stderr.write(f"   \033[1;31mLogging write failed: {e}\033[0m\n\n")
        
    # --- PHASE 3: Synthesis ---
    synthesis_start = time.time()
    synthesis_loader = InlineSpinner("Executing Gemini Draco Judge synthesis")
    synthesis_loader.start()
    
    final_output = execute_synthesis(prompt, all_reports)
    
    elapsed_synthesis = time.time() - synthesis_start
    synthesis_loader.stop()
    
    if final_output and not final_output.startswith("[SYSTEM ERROR]") and not final_output.startswith("[ERROR]"):
        sys.stderr.write(f"   \033[90mCompleted in {elapsed_synthesis:.1f}s\033[0m\n\n")
        
        # Save the final synthesized response to final_output.md inside logs/
        try:
            final_output_path = os.path.join(LOGS_DIR, "final_output.md")
            with open(final_output_path, "w", encoding="utf-8") as f:
                f.write(final_output)
        except Exception as e:
            sys.stderr.write(f"   \033[1;31mFailed to save final_output.md: {e}\033[0m\n\n")
    else:
        sys.stderr.write(f"   \033[1;31mSynthesis step failed.\033[0m\n\n")
        
    return final_output


