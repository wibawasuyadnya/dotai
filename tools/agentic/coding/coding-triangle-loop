                    # Code was accidentally pasted on the first line; inject it as the first element
                    lines.append(input_path)
                    print("\033[37m[sys] Code paste detected. Capturing remainder automatically...\033[0m")
                else:
                    # High contrast, readable instructions text
                    print("\n\033[37mPaste your raw draft code block below (processing starts automatically when pasting stops):\033[0m\n")
                    lines.append(input())
                
                # Asynchronously capture all remaining lines instantly
                while True:
                    r, _, _ = select.select([sys.stdin], [], [], 0.1)
                    if r:
                        line = sys.stdin.readline()
                        if not line:
                            break
                        lines.append(line.rstrip('\r\n'))
                    else:
                        break
                draft_code = "\n".join(lines).strip()
        except (KeyboardInterrupt, EOFError):
            print("\nExiting.")
            safe_exit(0)

