    print("\033[1;34m── CODING-TRIANGLE-LOOP: AUDITED CODE PREVIEW ──────────────────────────────\033[0m")
    print_boxed_prompt(refactored_code)
    print("\n\033[37mCommands: [Enter] Proceed to Pass 3 (Simplify & Polish)  |  [/q] Quit without copying\033[0m")
    
    try:
        user_input = input("\n❯ ").strip()
    except (KeyboardInterrupt, EOFError):
        print("\nExiting.")
        safe_exit(0)
        
    if user_input == "/q":
