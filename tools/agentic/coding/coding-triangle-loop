        print("\033[1;34m── CODING-TRIANGLE-LOOP: DRAFT SCRIPT INGESTION ────────────────────────────\033[0m")
        try:
            input_path = input("\033[1;32m[PWT] Enter file path to your draft script (or press Enter to paste raw code):\033[0m ").strip()
            
            # Smart, forgiving parser to catch accidental raw code pasted directly onto the first prompt
            is_raw_code = any(x in input_path for x in ["import ", "def ", "class ", "#", "while ", "import\t", "="]) or len(input_path.splitlines()) > 1
            
            if input_path and os.path.exists(input_path) and not is_raw_code:
