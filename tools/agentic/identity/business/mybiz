#!/usr/bin/env python3
import os
import sys

SKILL_PATH = "$HOME/.config/local-ai/skills/identity/business/mybiz.md"

def main():
    if not os.path.exists(SKILL_PATH):
        print(f"Error: Identity profile missing at {SKILL_PATH}", file=sys.stderr)
        sys.exit(1)
        
    with open(SKILL_PATH, "r", encoding="utf-8") as f:
        print("=== IDENTITY PROFILE ===")
        print(f.read().strip())
        print("========================\n")
        
    if len(sys.argv) > 1:
        print(f"TASK DIRECTIVE: {' '.join(sys.argv[1:])}")

if __name__ == "__main__":
    main()
