# 5. Dynamic Directory Skill Scanner
def list_prompt_skills():
    meta_dir = os.path.join(CFG_DIR, "skills", "meta", "prompt")
    default_skills = [
        ("prompt-writer-image.md", "General (Style-Suggesting)", DEFAULT_PRIMING_SKILL),
        ("prompt-writer-image-2.md", "Style-Neutral (Image-to-Image)", DEFAULT_NEUTRAL_SKILL)
    ]
    
    if not os.path.exists(meta_dir):
        return default_skills
        
    try:
        files = sorted([f for f in os.listdir(meta_dir) if f.startswith("prompt-writer-image") and f.endswith(".md")])
        skills = []
        for f in files:
            if f == "prompt-writer-image.md":
                skills.append((f, "General (Style-Suggesting)", DEFAULT_PRIMING_SKILL))
            elif f == "prompt-writer-image-2.md":
                skills.append((f, "Style-Neutral (Image-to-Image)", DEFAULT_NEUTRAL_SKILL))
            else:
                suffix_match = re.search(r'image-(.*?)\.md', f)
                suffix = suffix_match.group(1) if suffix_match else f
                skills.append((f, f"Custom-{suffix} ({f})", None))
        return skills if skills else default_skills
    except Exception:
        return default_skills

def load_priming_skill(filename, fallback_content):
    path = os.path.join(CFG_DIR, "skills", "meta", "prompt", filename)
    if os.path.exists(path):
        try:
            with open(path, "r") as f:
                return f.read().strip()
        except Exception:
            pass
    return fallback_content or DEFAULT_PRIMING_SKILL

# 6. Local Context Harvester
def load_project_context():
    context = []
    cwd = os.getcwd()
    
    try:
        files = [f for f in os.listdir(cwd) if not f.startswith('.')]
        if files:
            context.append(f"Directory Contents (ls):\n{', '.join(files[:30])}")
    except Exception:
        pass
        
    readme_path = None
    skeleton_path = None
    check_dir = cwd
    
    while True:
        for r_name in ["README.md", "readme.md", "Readme.md"]:
            p = os.path.join(check_dir, r_name)
            if os.path.exists(p):
                readme_path = p
                break
        for s_name in ["skeleton-ai.json", "skeleton.json"]:
            p = os.path.join(check_dir, s_name)
            if os.path.exists(p):
                skeleton_path = p
                break
        parent_dir = os.path.dirname(check_dir)
        if (readme_path and skeleton_path) or parent_dir == check_dir:
            break
        check_dir = parent_dir
        
    if readme_path:
        try:
            with open(readme_path, "r", encoding="utf-8", errors="ignore") as f:
                context.append(f"Project README.md ({os.path.relpath(readme_path, cwd)}):\n{f.read(1500).strip()}")
        except Exception:
            pass
            
    if skeleton_path:
        try:
            with open(skeleton_path, "r", encoding="utf-8", errors="ignore") as f:
                lines = [f.readline().strip() for _ in range(50)]
                context.append(f"Project Skeleton Map ({os.path.relpath(skeleton_path, cwd)}):\n" + "\n".join(lines))
        except Exception:
            pass
            
    return "\n\n---\n\n".join(context)

# 7. Adaptive Quality Metrics Calculator
def calculate_metrics(text):
    if not text:
        return 0, "\033[1;31mLOW\033[0m"
    words = text.split()
    tokens = int(len(words) * 1.3)
    lower_text = text.lower()
    
    has_context = "<context>" in lower_text and "</context>" in lower_text
    has_elements = "<elements>" in lower_text and "</elements>" in lower_text
    has_guardrails = "<guardrails>" in lower_text and "</guardrails>" in lower_text
    has_compiled = "<compiled_prompt>" in lower_text and "</compiled_prompt>" in lower_text
    
    score = 0
    if has_context: score += 25
    if has_elements: score += 25
    if has_guardrails: score += 25
    if has_compiled: score += 25
    
    if score >= 100:
        rating = "\033[1;32mHIGH\033[0m"
    elif score >= 50:
        rating = "\033[1;33mMEDIUM\033[0m"
    else:
        rating = "\033[1;31mLOW\033[0m"
    
    return tokens, rating

# 8. Unified Streaming Cascade Client with Active Logger
def call_service(messages):
    configs, gkey, okey, ckey, curl = [], os.environ.get("GEMINI_API_KEY"), os.environ.get("OPENROUTER_API_KEY"), os.environ.get("CLOUD_API_KEY"), os.environ.get("CLOUD_API_URL")
    if gkey: 
        target_model = os.environ.get("CLOUD_MODEL", "gemini-3.1-flash-lite")
        if "3.1-flash-lite" in target_model:
            target_model = "gemini-1.5-flash"
        configs.append(("https://generativelanguage.googleapis.com/v1beta/openai/chat/completions", {"Authorization": f"Bearer {gkey}"}, target_model, {}, 15))
    if okey:
        m = os.environ.get("OPENROUTER_MODEL", "openrouter/free")
        configs.append(("https://openrouter.ai/api/v1/chat/completions", {"Authorization": f"Bearer {okey}", "HTTP-Referer": "https://github.com/suyadnya/orkesai"}, m, {}, 20))
    if ckey and curl: 
        configs.append((curl, {"Authorization": f"Bearer {ckey}"}, os.environ.get("CLOUD_MODEL"), {}, 30))
    configs.append(("http://localhost:8080/v1/chat/completions", {}, "local-model", {}, 180))
    
    spinner = InlineSpinner()
    for url, headers, model, extra, timeout in configs:
        body = {"messages": messages, "stream": True, **extra}
        if model: body["model"] = model
        req = urlreq.Request(url, data=json.dumps(body).encode("utf-8"), headers={"Content-Type": "application/json", **headers}, method="POST")
        retries, backoff = 2, 1.5
        while retries >= 0:
            try:
                spinner.start()
                with urlreq.urlopen(req, timeout=timeout) as response:
                    spinner.stop()
                    
                    try:
                        p = "gemini" if "generativelanguage" in url else "openrouter" if "openrouter" in url else None
                        if p:
                            with open(os.path.join(CFG_DIR, ".request_log"), "a") as lf:
                                lf.write(f"{int(time.time())}|{p}\n")
                    except Exception:
                        pass
                        
                    first, acc = True, []
                    for line in response:
                        dec = line.decode("utf-8").strip()
                        if not dec: continue
                        if dec.startswith("data:"): dec = dec[5:].strip()
                        if dec == "[DONE]": continue
                        try:
                            data = json.loads(dec)
                            content = ""
                            if "choices" in data and data["choices"]: 
                                content = data["choices"][0].get("delta", {}).get("content", "")
                            elif "candidates" in data and data["candidates"]: 
                                content = data["candidates"][0].get("content", {}).get("parts", [{}])[0].get("text", "")
                            if content:
                                if first:
                                    sys.stdout.write("\n\033[2m[Streaming response...]\033[0m\n")
                                    sys.stdout.flush()
                                    first = False
                                sys.stdout.write(content)
                                sys.stdout.flush()
                                acc.append(content)
                        except: pass
                    print("")
                    return "".join(acc)
            except urlerr.HTTPError as e:
                spinner.stop()
                if e.code == 429 and retries > 0: 
                    time.sleep(backoff); retries, backoff = retries - 1, backoff * 2
                else:
                    break
            except Exception:
                spinner.stop()
                break
    raise RuntimeError("All fallback/local servers are offline.")

# 9. Mathematically Aligned Render Helper
def print_boxed_prompt(text):
    if not text:
        return
    lines = text.splitlines()
    term_width = 80
    try:
        term_width = os.get_terminal_size().columns
    except Exception:
        pass
    box_width = min(80, term_width - 4)
    box_width = max(10, box_width)
    text_width = box_width - 6
    
    print("\033[38;5;244m┌" + "─" * (box_width - 2) + "┐\033[0m")
    for line in lines:
        if not line.strip():
            print(f"\033[38;5;244m│\033[0m  {' ' * text_width}  \033[38;5;244m│\033[0m")
            continue
        wrapped_lines = textwrap.wrap(line, width=text_width)
        for w_line in wrapped_lines:
            print(f"\033[38;5;244m│\033[0m  {w_line:<{text_width}}  \033[38;5;244m│\033[0m")
    print("\033[38;5;244m└" + "─" * (box_width - 2) + "┘\033[0m")

# 10. Clipboard Export
def copy_to_clipboard(text):
    for cmd in [['wl-copy'], ['xclip', '-selection', 'clipboard']]:
        try:
            p = subprocess.Popen(cmd, stdin=subprocess.PIPE, stderr=subprocess.DEVNULL)
            p.communicate(input=text.encode('utf-8'))
            if p.returncode == 0:
                return True
        except Exception:
            pass
    return False

# 11. Main Interactive TUI Loop
def main():
    try:
        os.makedirs(CFG_DIR, exist_ok=True)
    except Exception as e:
        sys.stderr.write(f"\033[1;31m[sys] Directory initialization error: {e}\033[0m\n")

    # Safe interactive prompts written strictly to stderr
    raw_intent = prompt_user("\033[1;32m[PWT-Image] Enter design intent or banner requirements:\033[0m ")
    if not raw_intent:
        sys.stderr.write("Error: Design intent cannot be empty.\n")
        safe_exit(1)
        
    available_skills = list_prompt_skills()
    
    sys.stderr.write("\n\033[1;32m[PWT-Image] Select Active Profile:\033[0m\n")
    for idx, (_, name, _) in enumerate(available_skills):
        sys.stderr.write(f"  \033[1m{idx + 1}\033[0m. {name}\n")
    sys.stderr.flush()
        
    sel_input = prompt_user(f"\nSelection [Default: 1]: ")
    sel_idx = 0
    if sel_input:
        try:
            val = int(sel_input) - 1
            if 0 <= val < len(available_skills):
                sel_idx = val
        except ValueError:
            sel_idx = 0
            
    selected_filename, selected_name, fallback_content = available_skills[sel_idx]
    
    priming_skill = load_priming_skill(selected_filename, fallback_content)
    project_context = load_project_context()
    
    user_payload = f"Create an optimized image prompt based on this raw intent:\n\nIntent: {raw_intent}"
    if project_context:
        user_payload += f"\n\nActive Project Directory Context (Use this to match style, name, or aesthetic themes):\n\n{project_context}"
    
    history = [
        {"role": "system", "content": priming_skill},
        {"role": "user", "content": user_payload}
    ]
    
    current_prompt = ""
    modifications = []
    notification_msg = ""
    dirty = True
    
    while True:
        if dirty:
            os.system("clear")
            print("\033[1;34m── IMAGE-PROMPT CONSOLE ────────────────────────────────────────────────────\033[0m")
            if notification_msg:
                print(f" {notification_msg}")
                notification_msg = ""
            print(f"\033[38;5;244m[INTENT]\033[0m \"{raw_intent}\"")
            print(f"\033[38;5;244m[MODE  ]\033[0m \033[1;32m{selected_name}\033[0m")
            if modifications:
                print(f"\033[38;5;244m[TWEAKS]\033[0m {', '.join(f'\"{m}\"' for m in modifications)}")
                
            print("\n\033[1;33m[Generating fresh image prompt layout...]\033[0m")
            
            try:
                current_prompt = call_service(history)
            except Exception as e:
                print(f"\033[1;31mAPI Error:\033[0m {str(e)}")
                safe_exit(1)
                
            dirty = False
            
        os.system("clear")
        tokens, rating = calculate_metrics(current_prompt)
        
        print("\033[1;34m── IMAGE-PROMPT CONSOLE ────────────────────────────────────────────────────\033[0m")
        if notification_msg:
            print(f" {notification_msg}")
            notification_msg = ""
        print(f"\033[38;5;244m[METRICS]\033[0m Token Count: \033[1m{tokens}\033[0m | Quality Rating: {rating}")
        print(f"\033[38;5;244m[INTENT ]\033[0m \"{raw_intent}\"")
        print(f"\033[38;5;244m[MODE   ]\033[0m \033[1;32m{selected_name}\033[0m")
        if modifications:
            print(f"\033[38;5;244m[TWEAKS ]\033[0m {', '.join(f'\"{m}\"' for m in modifications)}")
            
        print("\n\033[1;32m[GENERATED IMAGE PROMPT]\033[0m")
        print_boxed_prompt(current_prompt)
        
        commands = [
            "[/c] Copy Compiled Prompt", 
            "[/e] Rewrite Intent", 
            "[/q] Quit"
        ]
        
        print("\n\033[37mCommands:  " + "  |  ".join(commands) + "\033[0m")
        print("\033[37mOr, type any tweak/adjustment instruction to reiterate directly.\033[0m")
        
        user_input = prompt_user("\n❯ ")
        
        if not user_input:
            continue
            
        if user_input == "/c":
            compiled_match = re.search(r'<compiled_prompt>\n?(.*?)\n?</compiled_prompt>', current_prompt, re.DOTALL | re.IGNORECASE)
            text_to_copy = compiled_match.group(1).strip() if compiled_match else current_prompt.strip()
            text_to_copy = re.sub(r'^```(?:text|markdown)?\n|```$', '', text_to_copy, flags=re.MULTILINE)
            
            if copy_to_clipboard(text_to_copy):
                notification_msg = "\033[1;32m[sys] Success! Copied optimized prompt to clipboard. Session active.\033[0m"
            else:
                notification_msg = "\033[1;31m[sys] Clipboard utility not found. Displaying output:\033[0m"
                print(text_to_copy)
                
            dirty = False
            
        elif user_input == "/e":
            new_intent = prompt_user("\n\033[1;32m[PWT-Image] Enter new intent:\033[0m ")
            if not new_intent:
                continue
            confirm = prompt_user(f"\033[1;33mConfirm rewrite intent (y/N)? \033[0m").lower()
            if confirm in ['y', 'yes']:
                raw_intent = new_intent
                
                # Dynamic selection list on rewrite
                available_skills = list_prompt_skills()
                sys.stderr.write("\n\033[1;32m[PWT-Image] Select Active Profile:\033[0m\n")
                for idx, (_, name, _) in enumerate(available_skills):
                    sys.stderr.write(f"  \033[1m{idx + 1}\033[0m. {name}\n")
                sys.stderr.flush()
                
                sel_input = prompt_user(f"\nSelection [Default: 1]: ")
                sel_idx = 0
                if sel_input:
                    try:
                        val = int(sel_input) - 1
                        if 0 <= val < len(available_skills):
                            sel_idx = val
                    except ValueError:
                        sel_idx = 0
                
                selected_filename, selected_name, fallback_content = available_skills[sel_idx]
                priming_skill = load_priming_skill(selected_filename, fallback_content)
                
                user_payload = f"Create an optimized image prompt based on this raw intent:\n\nIntent: {raw_intent}"
                if project_context:
                    user_payload += f"\n\nActive Project Directory Context (Use this to match style, name, or aesthetic themes):\n\n{project_context}"
                history = [
                    {"role": "system", "content": priming_skill},
                    {"role": "user", "content": user_payload}
                ]
                modifications = []
                dirty = True
            
        elif user_input == "/q":
            print("\nExiting.")
            safe_exit(0)
            
        else:
            confirm = prompt_user(f"\033[1;33mConfirm tweak: \"{user_input}\" (y/N)? \033[0m").lower()
            if confirm in ['y', 'yes']:
                modifications.append(user_input)
                history.append({"role": "assistant", "content": current_prompt})
                history.append({
                    "role": "user", 
                    "content": f"Update the previous image prompt with this specific adjustment: {user_input}. Respect the requested formatting rule to output only raw, structurally-bracketed or XML-tagged blocks."
                })
                dirty = True

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        # Stop any active spinners, clean stderr, and exit gracefully
        sys.stderr.write("\n\033[1;33m[sys] Exiting cleanly on user interrupt.\033[0m\n")
        safe_exit(0)
