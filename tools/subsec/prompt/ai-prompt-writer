# 5. Local Quality Metrics Calculator
def calculate_metrics(text):
    words = text.split()
    tokens = int(len(words) * 1.3)
    
    # Check for structural patterns
    has_context = "<context>" in text.lower() and "</context>" in text.lower()
    has_objective = "<objective>" in text.lower() and "</objective>" in text.lower()
    has_guardrails = "<guardrails>" in text.lower() and "</guardrails>" in text.lower()
    has_output_format = "<output_format>" in text.lower() and "</output_format>" in text.lower()
    
    score = 0
    if has_context: score += 25
    if has_objective: score += 25
    if has_guardrails: score += 25
    if has_output_format: score += 25
    
    if score >= 100:
        rating = "\033[1;32mHIGH\033[0m"
    elif score >= 50:
        rating = "\033[1;33mMEDIUM\033[0m"
    else:
        rating = "\033[1;31mLOW\033[0m"
    
    return tokens, rating

# 6. Unified Streaming Cascade Client with Active Logger
def call_service(messages):
    configs, gkey, okey, ckey, curl = [], os.environ.get("GEMINI_API_KEY"), os.environ.get("OPENROUTER_API_KEY"), os.environ.get("CLOUD_API_KEY"), os.environ.get("CLOUD_API_URL")
    if gkey: 
        target_model = os.environ.get("CLOUD_MODEL", "gemini-3.1-flash-lite")
        if "3.1-flash-lite" in target_model:
            target_model = "gemini-1.5-flash"
        configs.append(("https://generativelanguage.googleapis.com/v1beta/openai/chat/completions", {"Authorization": f"Bearer {gkey}"}, target_model, {}, 15))
    if okey:
        m = os.environ.get("OPENROUTER_MODEL", "openrouter/free")
        configs.append(("https://openrouter.ai/api/v1/chat/completions", {"Authorization": f"Bearer {okey}", "HTTP-Referer": "https://github.com/suyadnya/orkesai"}, m, {}, 20))
    if ckey and curl: 
        configs.append((curl, {"Authorization": f"Bearer {ckey}"}, os.environ.get("CLOUD_MODEL"), {}, 30))
    configs.append(("http://localhost:8080/v1/chat/completions", {}, "local-model", {}, 180))
    
    spinner = InlineSpinner()
    for url, headers, model, extra, timeout in configs:
        body = {"messages": messages, "stream": True, **extra}
        if model: body["model"] = model
        req = urlreq.Request(url, data=json.dumps(body).encode("utf-8"), headers={"Content-Type": "application/json", **headers}, method="POST")
        retries, backoff = 2, 1.5
        while retries >= 0:
            try:
                spinner.start()
                with urlreq.urlopen(req, timeout=timeout) as response:
                    spinner.stop()
                    
                    try:
                        p = "gemini" if "generativelanguage" in url else "openrouter" if "openrouter" in url else None
                        if p:
                            with open(os.path.join(CFG_DIR, ".request_log"), "a") as lf:
                                lf.write(f"{int(time.time())}|{p}\n")
                    except Exception:
                        pass
                        
                    first, acc = True, []
                    for line in response:
                        dec = line.decode("utf-8").strip()
                        if not dec: continue
                        if dec.startswith("data:"): dec = dec[5:].strip()
                        if dec == "[DONE]": continue
                        try:
                            data = json.loads(dec)
                            content = ""
                            if "choices" in data and data["choices"]: 
                                content = data["choices"][0].get("delta", {}).get("content", "")
                            elif "candidates" in data and data["candidates"]: 
                                content = data["candidates"][0].get("content", {}).get("parts", [{}])[0].get("text", "")
                            if content:
                                if first:
                                    sys.stdout.write("\n\033[2m[Streaming response...]\033[0m\n")
                                    sys.stdout.flush()
                                    first = False
                                sys.stdout.write(content)
                                sys.stdout.flush()
                                acc.append(content)
                        except: pass
                    print("")
                    return "".join(acc)
            except urlerr.HTTPError as e:
                spinner.stop()
                if e.code == 429 and retries > 0: 
                    time.sleep(backoff); retries, backoff = retries - 1, backoff * 2
                else:
                    break
            except Exception:
                spinner.stop()
                break
    raise RuntimeError("All fallback/local servers are offline.")

# 7. Mathematically Aligned Render Helper
def print_boxed_prompt(text):
    if not text:
        return
    lines = text.splitlines()
    term_width = 80
    try:
        term_width = os.get_terminal_size().columns
    except Exception:
        pass
    box_width = min(80, term_width - 4)
    box_width = max(10, box_width)
    text_width = box_width - 6
    
    print("\033[38;5;244m┌" + "─" * (box_width - 2) + "┐\033[0m")
    for line in lines:
        if not line.strip():
            print(f"\033[38;5;244m│\033[0m  {' ' * text_width}  \033[38;5;244m│\033[0m")
            continue
        wrapped_lines = textwrap.wrap(line, width=text_width)
        for w_line in wrapped_lines:
            print(f"\033[38;5;244m│\033[0m  {w_line:<{text_width}}  \033[38;5;244m│\033[0m")
    print("\033[38;5;244m└" + "─" * (box_width - 2) + "┘\033[0m")

# 8. Clipboard Export
def copy_to_clipboard(text):
    for cmd in [['wl-copy'], ['xclip', '-selection', 'clipboard']]:
        try:
            p = subprocess.Popen(cmd, stdin=subprocess.PIPE, stderr=subprocess.DEVNULL)
            p.communicate(input=text.encode('utf-8'))
            if p.returncode == 0:
                return True
        except Exception:
            pass
    return False

# 9. Main Interactive TUI Loop
def main():
    try:
        os.makedirs(CFG_DIR, exist_ok=True)
    except Exception as e:
        sys.stderr.write(f"\033[1;31m[sys] Directory initialization error: {e}\033[0m\n")

    if not API_KEY:
        sys.stderr.write("\033[1;33m[sys] Warning: No cloud keys detected. Cascading directly to offline local server.\033[0m\n")
        
    try:
        raw_intent = input("\033[1;32m[PWT] Enter raw intent:\033[0m ").strip()
    except (KeyboardInterrupt, EOFError):
        print("\nExiting.")
        safe_exit(0)
        
    if not raw_intent:
        print("Error: Intent cannot be empty.")
        safe_exit(1)
        
    priming_skill = load_priming_skill()
    
    history = [
        {"role": "system", "content": priming_skill},
        {"role": "user", "content": f"Create a structured system prompt based on this raw intent:\n\n{raw_intent}"}
    ]
    
    current_prompt = ""
    modifications = []
    dirty = True
    
    while True:
        if dirty:
            os.system("clear")
            print("\033[1;34m── PROMPT-WRITER CONSOLE ───────────────────────────────────────────────────\033[0m")
            print(f"\033[38;5;244m[INTENT]\033[0m \"{raw_intent}\"")
            if modifications:
                print(f"\033[38;5;244m[TWEAKS]\033[0m {', '.join(f'\"{m}\"' for m in modifications)}")
                
            print("\n\033[1;33m[Generating fresh system prompt layout...]\033[0m")
            
            try:
                current_prompt = call_service(history)
            except Exception as e:
                print(f"\033[1;31mAPI Error:\033[0m {str(e)}")
                safe_exit(1)
                
            dirty = False
            
        os.system("clear")
        tokens, rating = calculate_metrics(current_prompt)
        
        print("\033[1;34m── PROMPT-WRITER CONSOLE ───────────────────────────────────────────────────\033[0m")
        print(f"\033[38;5;244m[METRICS]\033[0m Token Count: \033[1m{tokens}\033[0m | Quality Rating: {rating}")
        print(f"\033[38;5;244m[INTENT ]\033[0m \"{raw_intent}\"")
        if modifications:
            print(f"\033[38;5;244m[TWEAKS ]\033[0m {', '.join(f'\"{m}\"' for m in modifications)}")
            
        print("\n\033[1;32m[GENERATED SYSTEM PROMPT]\033[0m")
        print_boxed_prompt(current_prompt)
        
        commands = [
            "[/c] Copy Compiled Prompt & Exit", 
            "[/e] Rewrite Intent", 
            "[/q] Quit without copying"
        ]
        
        print("\n\033[37mCommands:  " + "  |  ".join(commands) + "\033[0m")
        print("\033[37mOr, type any tweak/adjustment instruction to reiterate directly.\033[0m")
        
        try:
            user_input = input("\n❯ ").strip()
        except (KeyboardInterrupt, EOFError):
            print("\nExiting.")
            safe_exit(0)
            
        if not user_input:
            continue
            
        if user_input == "/c":
            if copy_to_clipboard(current_prompt):
                print("\n\033[1;32m[sys] Success! Prompt compiled & copied to system clipboard!\033[0m")
            else:
                print("\n\033[1;31m[sys] Clipboard utility not found. Displaying raw output:\033[0m\n")
                print(current_prompt)
            safe_exit(0)
            
        elif user_input == "/e":
            raw_intent = input("\n\033[1;32m[PWT] Enter raw intent:\033[0m ").strip()
            if not raw_intent:
                print("Error: Intent cannot be empty.")
                sys.exit(1)
            history = [
                {"role": "system", "content": priming_skill},
                {"role": "user", "content": f"Create a structured system prompt based on this raw intent:\n\n{raw_intent}"}
            ]
            modifications = []
            dirty = True
            
        elif user_input == "/q":
            print("\nExiting.")
            safe_exit(0)
            
        else:
            confirm = input(f"\033[1;33mConfirm tweak: \"{user_input}\" (y/N)? \033[0m").strip().lower()
            if confirm in ['y', 'yes']:
                modifications.append(user_input)
                history.append({"role": "assistant", "content": current_prompt})
                history.append({
                    "role": "user", 
                    "content": f"Update the previous system prompt with this specific adjustment: {user_input}. Respect the requested formatting rule to output only raw, structurally-bracketed or XML-tagged blocks."
                })
                dirty = True

if __name__ == "__main__":
    main()
