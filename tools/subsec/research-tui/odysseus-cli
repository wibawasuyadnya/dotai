#!/usr/bin/env python3
import sys
import os
import asyncio
import warnings
warnings.filterwarnings("ignore")

# 1. Ensure we use the Odysseus virtualenv
venv_python = "/opt/odysseus/venv/bin/python3"
if os.path.exists(venv_python) and sys.executable != venv_python:
    os.execl(venv_python, venv_python, *sys.argv)

# 2. Path injection for Odysseus
sys.path.insert(0, '/opt/odysseus')

from src.deep_research import DeepResearcher

async def run_research(topic):
    # 3. Use the same config Odysseus uses (or manual override)
    # You can read these from the .env file in /opt/odysseus/
    researcher = DeepResearcher(
        llm_endpoint="https://generativelanguage.googleapis.com/v1beta/openai/chat/completions",
        llm_model=os.environ.get("CLOUD_MODEL", "gemini-3.1-flash-lite"),
        llm_headers={"Authorization": f"Bearer {os.environ.get('GEMINI_API_KEY')}"},
        # --- ADD THESE PARAMETERS FOR LITE-TIER RATE SAFETY ---
        max_content_chars=8000,     # Limit raw page extraction blocks to 8k chars
        synthesis_window=4,         # Synthesize only the 4 most relevant findings per round
        max_urls_per_round=2        # Limit URLs fetched per round to prevent TPM spikes
    )
    return await researcher.research(topic)

if __name__ == "__main__":
    topic = " ".join(sys.argv[1:])
    if not topic:
        sys.exit(1)
    print(asyncio.run(run_research(topic)))
