class InlineSpinner:
    """A lightweight modern Braille spinner for high-fidelity terminal feedback."""
    def __init__(self, message="Working"):
        # 10-step circular Braille sequence used by gemini-cli and modern TUIs
        self.chars = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
        self.active = False
        self.thread = None
        self.message = message

    def _spin(self):
        idx = 0
        while self.active:
            # Render the animated Braille tick and the progress message
            sys.stderr.write(f"\r\033[1;36m{self.chars[idx % 10]}\033[0m {self.message}")
            sys.stderr.flush()
            idx += 1
            time.sleep(0.08)
        sys.stderr.write("\r\x1b[K")  # Clear line on stop
        sys.stderr.flush()

    def start(self):
        self.active = True
        self.thread = threading.Thread(target=self._spin, daemon=True)
        self.thread.start()

    def stop(self):
        self.active = False
        if self.thread:
            self.thread.join()

# --- KoKo-Style Clean Markdown Engine (Adapted from AI Summary TUI) ---

RE_BOLD = re.compile(r'\*\*(.*?)\*\*')
RE_ITALIC_STAR = re.compile(r'\*(.*?)\*')
RE_ITALIC_UNDER = re.compile(r'_(.*?)_')
RE_BACKTICK = re.compile(r'`(.*?)`')
RE_BULLET_STRIP = re.compile(r'^\s*([\*\-]|(\d+[\.\)]))\s+')
RE_HEADER_STRIP = re.compile(r'^(#+)\s*')
RE_LINK_STRIP = re.compile(r'\[(.*?)\]\((https?://.*?)\)')

def clean_markdown(text):
    if not text:
        return ""
    
    text = RE_BOLD.sub(r'\1', text)
    text = RE_ITALIC_STAR.sub(r'\1', text)
    text = RE_ITALIC_UNDER.sub(r'\1', text)
    text = RE_BACKTICK.sub(r'\1', text)
    text = RE_LINK_STRIP.sub(r'\1 (\2)', text)
    
    lines = []
    bullet_counter = 1
    for line in text.splitlines():
        stripped = line.strip()
        if not stripped:
            lines.append("")
            continue
            
        if RE_HEADER_STRIP.match(line):
            cleaned_header = RE_HEADER_STRIP.sub('', line).strip().upper()
            if cleaned_header:
                lines.append(f"\n{cleaned_header}")
            continue
            
        if RE_BULLET_STRIP.match(line):
            cleaned_content = RE_BULLET_STRIP.sub('', line).strip()
            if cleaned_content:
                lines.append(f"{bullet_counter:2d}.  {cleaned_content}")
                bullet_counter += 1
        else:
            lines.append(line)
            
    return "\n".join(lines).strip()

def wrap_text(text, width=80):
    wrapped_lines = []
    for line in text.split('\n'):
        if not line.strip():
            wrapped_lines.append("")
            continue
        words = line.split(' ')
        current_line = []
        for word in words:
            if sum(len(w) for w in current_line) + len(current_line) + len(word) > width:
                wrapped_lines.append(" ".join(current_line))
                current_line = [word]
            else:
                current_line.append(word)
        if current_line:
            wrapped_lines.append(" ".join(current_line))
    return "\n".join(wrapped_lines)

# --- Minimal TUI Helpers ---

def get_key():
    """Reads a single keypress cleanly using unbuffered reads to avoid lockups."""
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        ch_bytes = os.read(fd, 1)
        ch = ch_bytes.decode('utf-8', errors='ignore') if ch_bytes else ""
        if ch == '\033':
            # Check if there are more incoming characters (like arrow key codes)
            r, _, _ = select.select([sys.stdin], [], [], 0.05)
            if r:
                ch += os.read(fd, 2).decode('utf-8', errors='ignore')
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
    return ch

def get_text_input(prompt_text):
    """
    Prompts the user for text input. By leveraging standard library input(),
    system backspace handling, delete keys, and arrow keys are supported.
    """
    try:
        # \033[?25h ensures the terminal cursor is visible during typing
        user_input = input(f"\033[?25h\n \033[1;36m{prompt_text}\033[0m ")
        return user_input.strip()
    except (KeyboardInterrupt, EOFError):
        # Gracefully handle Ctrl+C or Ctrl+D as an empty escape return
        return ""

def print_header(title):
    sys.stdout.write("\033[2J\033[H")
    print(f"\033[1;36m=== {title} ===\033[0m\n")

# --- Bridge Logic ---
def run_research_engine(topic, use_hermes=False):
    """Orchestrates research threads cleanly without blocking pipe stalls."""
    if use_hermes:
        bridge_path = os.path.expanduser("~/.config/local-ai/tools/subsec/research-tui/hermes-cli")
    else:
        bridge_path = os.path.expanduser("~/.config/local-ai/tools/subsec/research-tui/odysseus-cli")
        
    try:
        # Spawn the bridge as a background pipe with buffered output
        process = subprocess.Popen(
            [bridge_path, topic],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True
        )
        
        # Wait for the process to complete. This releases the GIL,
        # allowing the InlineSpinner thread to spin smoothly in the background.
        stdout, _ = process.communicate()
        return stdout
    except Exception as e:
        return f"Error: {str(e)}"

def main():
    use_hermes = False
    args = sys.argv[1:]
    
    # Detect the optional --hermes flag in CLI arguments
    if len(args) > 0 and args[0] == "--hermes":
        use_hermes = True
        args = args[1:]
        
    if not args:
        topic = get_text_input("Research Subject:")
        if not topic:
            sys.exit(0)
            
        # Smart flag detection inside the interactive text prompt
        if topic.startswith("--hermes "):
            use_hermes = True
            topic = topic.replace("--hermes ", "", 1).strip()
        elif topic.startswith("-h "):
            use_hermes = True
            topic = topic.replace("-h ", "", 1).strip()
    else:
        topic = " ".join(args)
    
    engine_name = "Hermes" if use_hermes else "Odysseus"
    print_header(f"Researching ({engine_name}): {topic}")
    
    # Initialize the modern Braille spinner with a clear message
    spinner = InlineSpinner(f"Invoking {engine_name} research engine (running deep analysis)...")
    spinner.start()
    
    report = run_research_engine(topic, use_hermes)
    
    # Stop spinner and clear status line
    spinner.stop()
    
    # Run clean markdown engine and calculate terminal margins
    cols, _ = shutil.get_terminal_size()
    clean_report = clean_markdown(report)
    wrapped_report = wrap_text(clean_report, max(cols - 6, 40))
    
    # Display the result
    print("\n" + "=" * cols + "\n")
    print(wrapped_report)
    print("\n" + "=" * cols + "\n")
    
    # Key-listener exit prompt
    sys.stdout.write(" \033[1;36m[s]\033[0m Summary Read-Aloud  |  \033[1;33m[Any Other Key]\033[0m Exit")
    sys.stdout.flush()
    
    key = get_key()
    if key.lower() == 's':
        temp_path = "/tmp/deep_research_report.txt"
        try:
            with open(temp_path, "w") as f:
                f.write(report)
            
            # Clear screen before switching tool contexts
            sys.stdout.write("\033[2J\033[H")
            sys.stdout.flush()
            
            # Launch llmsum.py using expanded path resolution
            llmsum_path = os.path.expanduser("~/.config/local-ai/tools/subsec/ai-summary/llmsum.py")
            subprocess.run(["python3", llmsum_path, "--file", temp_path])
        except Exception as e:
            print(f"\nError starting KoKo Read-Aloud: {str(e)}")
            time.sleep(2)

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        # Clean terminal screen state restoration (restores buffer and cursor)
        sys.stdout.write("\033[?1049l\033[?25h\n\033[K")
        sys.stdout.flush()
        sys.exit(0)
