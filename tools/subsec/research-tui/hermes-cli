#!/usr/bin/env python3
# hermes-cli - Nous Research Hermes Agent Bridge v1.0.0 [suyadnya] [06-06-26]

import sys
import subprocess
import os
import shutil

def main():
    topic = " ".join(sys.argv[1:])
    if not topic:
        sys.exit(1)
        
    # Auto-resolve the active hermes binary path
    hermes_bin = (
        shutil.which("hermes") or 
        os.path.expanduser("~/.local/bin/hermes") or 
        os.path.expanduser("~/.hermes/bin/hermes")
    )
    
    # Prepend instructions to force Hermes into its native deep-research loops
    prompt = (
        f"Perform a deep, highly detailed and comprehensive research report on this topic. "
        f"Ensure all source citations and links are preserved inline: {topic}"
    )
    
    # -z ensures clean output on stdout (no banners or prompt boxes)
    cmd = [hermes_bin, "-z", prompt]
    
    try:
        # Redirect stderr to sys.stderr so you see active tool/planning logs,
        # and capture stdout to retrieve the final completed report.
        result = subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=sys.stderr,
            text=True,
            check=True
        )
        print(result.stdout)
    except Exception as e:
        sys.stderr.write(f"Hermes Agent execution failed: {str(e)}\n")
        sys.exit(1)

if __name__ == "__main__":
    main()
