# cp .env.example .env  — then fill in. This .env is only for the VPS stack.

# OpenRouter key used by the agents (openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ":80"            → plain HTTP (use with Tailscale or trusted LAN)
# "your.domain.com" → automatic HTTPS via Let's Encrypt (needs DNS → VPS IP)
SITE_ADDRESS=:80

# Login for the whole app (GUI + API). Generate the hash with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
# IMPORTANT: docker compose expands $ in this file — double every $ in the
# hash ($2a$14$... becomes $$2a$$14$$...), or generate it pre-escaped with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password' | sed 's/\$/$$/g'
GUI_USER=admin
GUI_PASS_HASH=
