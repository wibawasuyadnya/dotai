    skill = " ".join(s.lstrip("-") for s in os.environ.get("AI_ACTIVE_SKILL", "").split()) or "default"
    box_w = 46
    
    lines = [
        " >_ Local-AI Session Manager", "", 
        f" model:     {model}", 
        f" directory: {disp}", 
        f" skill:     {skill}", 
        f" database:  active ({tpm_count} facts, {turns} turns)"
    ]
    sys.stderr.write("\n\033[1;36m╭" + "─" * box_w + "╮\n\033[0m")
    for i, l in enumerate(lines):
        if i == 1:
            sys.stderr.write(f"\033[1;36m│\033[0m{' ':<{box_w}}\n\033[0m")
        else:
            style = "\033[1;37m" if i == 0 else "\033[2m"
            sys.stderr.write(f"\033[1;36m│\033[0m {style}{l:<{box_w-1}}\033[0m\033[1;36m│\n\033[0m")
    sys.stderr.write("\033[1;36m╰" + "─" * box_w + "╯\n\033[0m")
    sys.stderr.flush()


def init_db(workspace: str) -> None:
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    with closing(sqlite3.connect(db_path, timeout=10)) as conn:
        cur = conn.cursor()
        cur.execute("CREATE TABLE IF NOT EXISTS checkpoints (id INTEGER PRIMARY KEY AUTOINCREMENT, workspace TEXT NOT NULL, tag TEXT NOT NULL, history TEXT NOT NULL, timestamp INTEGER NOT NULL)")
        cur.execute("CREATE TABLE IF NOT EXISTS turns (id INTEGER PRIMARY KEY AUTOINCREMENT, workspace TEXT NOT NULL, user_msg TEXT NOT NULL, assistant_msg TEXT NOT NULL, tokens TEXT NOT NULL, timestamp INTEGER NOT NULL)")
        cur.execute("CREATE TABLE IF NOT EXISTS tpm_memories (key TEXT PRIMARY KEY, value TEXT NOT NULL, timestamp INTEGER NOT NULL)")
        cur.execute("CREATE INDEX IF NOT EXISTS idx_turns_workspace ON turns (workspace)")
        cur.execute("CREATE INDEX IF NOT EXISTS idx_checkpoints_workspace ON checkpoints (workspace)")
        conn.commit()


def save_checkpoint(workspace: str, tag: str) -> None:
    try:
        hist_data = sys.stdin.read().strip()
        json.loads(hist_data)
    except Exception:
        sys.stderr.write("\033[1;31m[session-mgr] Invalid history data received via stdin.\033[0m\n")
        sys.exit(1)
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    with closing(sqlite3.connect(db_path, timeout=10)) as conn:
        cur = conn.cursor()
        cur.execute("INSERT INTO checkpoints (workspace, tag, history, timestamp) VALUES (?, ?, ?, ?)", (workspace, tag, hist_data, int(time.time())))
        conn.commit()
    sys.stderr.write(f"\033[1;32m[session-mgr] Checkpoint '{tag}' saved to SQLite.\033[0m\n")


def rollback_checkpoint(workspace: str) -> None:
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    rows = []
    if os.path.exists(db_path):
        with closing(sqlite3.connect(db_path, timeout=10)) as conn:
            cur = conn.cursor()
            cur.execute("SELECT tag, history, timestamp FROM checkpoints WHERE workspace = ? ORDER BY timestamp DESC", (workspace,))
            rows = cur.fetchall()
    
    is_global = False
    global_rows = []
    
    # GLOBAL HANDOFF: If no local checkpoints exist, scan for other workspace backups
    if not rows:
        is_global = True
        for file in os.listdir(SESSIONS_DIR):
            if file.endswith(".db") and file != f"{workspace}.db":
                other_ws = file[:-3]
                other_db = os.path.join(SESSIONS_DIR, file)
                try:
                    with closing(sqlite3.connect(other_db, timeout=2)) as conn2:
                        other_cur = conn2.cursor()
                        other_cur.execute("SELECT tag, history, timestamp FROM checkpoints ORDER BY timestamp DESC")
                        for tag, history, ts in other_cur.fetchall():
                            global_rows.append((tag, history, ts, other_ws))
                except Exception:
                    pass
                    
    print_session_box(workspace)
    if not rows and not global_rows:
        sys.stderr.write(f"\033[1;31m[session-mgr] No checkpoints found locally or globally.\033[0m\n")
        sys.stderr.flush()
        sys.exit(0)
        
    display_rows = global_rows if is_global else rows
    title = "--- Global Checkpoints (Clonable) ---" if is_global else "--- Active Checkpoints (SQLite) ---"
    sys.stderr.write(f"\n\033[1;36m{title}\033[0m\n")
    
    for idx, item in enumerate(display_rows):
        if is_global:
            tag, history, ts, src_ws = item
            src_info = f" \033[1;30m(from '{src_ws}')\033[0m"
        else:
            tag, history, ts = item
            src_info = ""
        try: turns_len = len(json.loads(history))
        except Exception: turns_len = 0
        date_str = time.strftime('%Y-%m-%d %H:%M:%S', time.localtime(ts))
        sys.stderr.write(f"[{idx}] \033[1;32m{tag}\033[0m ({turns_len} turns){src_info} - {date_str}\n")
        
    action_text = "clone and load" if is_global else "load"
    sys.stderr.write(f"\n\033[2mSelect index to {action_text}, or press Esc to cancel: \033[0m\033[?25l")
    sys.stderr.flush()
    
    try:
        key = ""
        while True:
            if not key: key = get_key()
            if not key:
                sys.stderr.write("\033[?25h\033[1;30mSelect Index: \033[0m")
                sys.stderr.flush()
                try:
                    with open("/dev/tty", "r+", encoding="utf-8") as tty_in:
                        key = tty_in.readline().strip()
                except KeyboardInterrupt: key = '\x1b'
                except Exception: key = ''
            if key in ('\x03', '\x1b', 'q', 'Q', ''):
                sys.stderr.write("\r\x1b[KCancelled.\n")
                sys.exit(0)
            if key.isdigit() and int(key) < len(display_rows):
                selected_item = display_rows[int(key)]
                if is_global:
                    tag, history, ts, src_ws = selected_item
                    # Clone the global checkpoint dynamically into your fresh workspace database
                    init_db(workspace)
                    with closing(sqlite3.connect(db_path, timeout=10)) as conn3:
                        cur3 = conn3.cursor()
                        cur3.execute("INSERT OR REPLACE INTO checkpoints (workspace, tag, history, timestamp) VALUES (?, ?, ?, ?)", (workspace, tag, history, int(time.time())))
                        conn3.commit()
                    sys.stderr.write(f"\r\x1b[K\033[1;32m[session-mgr] Cloned checkpoint '{tag}' from '{src_ws}' to '{workspace}'!\033[0m\n")
                else:
                    tag, history, ts = selected_item
                    sys.stderr.write(f"\r\x1b[K\033[1;32m[session-mgr] Loading checkpoint '{tag}'...\033[0m\n")
                print(history)
                break
            else:
                sys.stderr.write(f"\r\x1b[K\033[1;31m[session-mgr] Invalid selection. Enter 0-{len(display_rows)-1}: ")
                sys.stderr.flush()
                key = ""
    finally:
        sys.stderr.write("\033[?25h")
        sys.stderr.flush()


def log_turn(workspace: str, user_msg: str, assistant_msg: str) -> None:
    if "### Real-time System Context:" in user_msg:
        user_msg = user_msg.split("User Question:", 1)[-1].strip()
    
    cleaned = re.sub(r"[^\w\s]", " ", user_msg.lower())
    tokens_str = " ".join([w for w in cleaned.split() if len(w) > 1 and w not in STOP_WORDS])
    
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    with closing(sqlite3.connect(db_path, timeout=10)) as conn:
        cur = conn.cursor()
        cur.execute("INSERT INTO turns (workspace, user_msg, assistant_msg, tokens, timestamp) VALUES (?, ?, ?, ?, ?)", (workspace, user_msg, assistant_msg, tokens_str, int(time.time())))
        conn.commit()


def get_turns_count(workspace: str) -> None:
