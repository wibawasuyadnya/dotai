    if os.path.exists(db_path):
        with closing(sqlite3.connect(db_path, timeout=10)) as conn:
            cur = conn.cursor()
            cur.execute("SELECT COUNT(*) FROM turns WHERE workspace = ?", (workspace,))
            print(cur.fetchone()[0])
    else:
        print(0)
        
def clear_turns(workspace: str) -> None:
    """Wipes all logged conversational turns from the turns table for this workspace."""
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    if os.path.exists(db_path):
        with closing(sqlite3.connect(db_path, timeout=10)) as conn:
            cur = conn.cursor()
            cur.execute("DELETE FROM turns WHERE workspace = ?", (workspace,))
            conn.commit()


