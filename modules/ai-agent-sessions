                cur = conn.cursor()
                cur.execute("SELECT COUNT(*) FROM turns WHERE workspace = ?", (workspace,))
                turns = cur.fetchone()[0]
                cur.execute("SELECT COUNT(*) FROM checkpoints WHERE workspace = ?", (workspace,))
                checkpoints = cur.fetchone()[0]
                cur.execute("SELECT COUNT(*) FROM tpm_memories")
                tpm_count = cur.fetchone()[0]
        except Exception: pass
    home_dir = os.path.expanduser("~")
    ws_path = os.environ.get("AI_WORKSPACE_PATH") or (os.path.join(home_dir, workspace.replace("-", "/")) if workspace.startswith(".config") else workspace.replace("-", "/"))
    disp = ws_path.replace(home_dir, "~", 1) if ws_path.startswith(home_dir) else ws_path
