import sys
import os
import json
import sqlite3
import time
import re
from contextlib import closing
from typing import List

CFG_DIR = os.path.expanduser("~/.config/local-ai")
SESSIONS_DIR = os.path.join(CFG_DIR, "projects", "database")

TOKEN_RE = re.compile(r"[^\w\s]")
STOP_WORDS = {"is", "what", "it", "do", "any", "i", "have", "the", "a", "an", "on", "to", "for", "me", "you", "my", "your", "we", "us", "are", "about", "in", "how"}

def tokenize(text: str) -> List[str]: 
    return [w for w in TOKEN_RE.sub(" ", text.lower()).split() if len(w) > 1 and w not in STOP_WORDS] if text else []

try:
    import agent_ui as ui
    get_key = ui.get_key
except ImportError:
    def get_key() -> str:
        import tty, termios, select
        fd = sys.stdin.fileno()
        try: old = termios.tcgetattr(fd)
        except: return sys.stdin.read(1)
        try:
            tty.setraw(fd)
            r = os.read(fd, 1)
            if r == b'\x1b' and select.select([fd], [], [], 0.05)[0]:
                r += os.read(fd, 2)
            return r.decode("utf-8", errors="ignore")
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)


def search_past_context(workspace: str, query: str) -> None:
    """Semantic Recall: Searches and injects highly relevant past conversation turns."""
    q_tokens = set(tokenize(query))
    if not q_tokens: return
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    if not os.path.exists(db_path): return
    with closing(sqlite3.connect(db_path, timeout=10)) as conn:
        cur = conn.cursor()
        cur.execute("SELECT user_msg, assistant_msg, tokens, timestamp FROM turns WHERE workspace = ?", (workspace,))
        rows = cur.fetchall()
    candidates = []
    for user_msg, assistant_msg, tokens, ts in rows:
        t_tokens = set(tokens.split())
        score = len(q_tokens & t_tokens) / len(q_tokens | t_tokens) if (q_tokens & t_tokens) else 0.0
        if score >= 0.35:
            candidates.append((score, user_msg, assistant_msg, ts))
    if not candidates: return
    candidates.sort(key=lambda x: -x[0])
    num_opts, current_idx = len(candidates), 0
    sys.stderr.write("\033[?25l")
    sys.stderr.flush()
    try:
        while True:
            _, user_msg, assistant_msg, ts = candidates[current_idx]
            idx_str = f"[{current_idx + 1:02d}/{num_opts:02d}] ❯ " if num_opts > 1 else ""
            disp = user_msg.strip().replace("\n", " ")
            if len(disp) > 40: disp = disp[:47] + "..."
            date_str = time.strftime('%Y-%m-%d %H:%M', time.localtime(ts))
            sys.stderr.write(f"\r\x1b[K\033[2m{idx_str}[memory] ({date_str})\033[0m\n\r\x1b[K\033[3m   \"{disp}\"\033[0m [↵ load  d: disable  Esc/Arrows: skip]: ")
            sys.stderr.flush()
            key = get_key()
            sys.stderr.write("\r\x1b[K\x1b[1A\r\x1b[K")
            sys.stderr.flush()
            if key == '\x03':
                sys.stderr.write("Cancelled.\n")
                sys.exit(2)
            elif key in ('\r', '\n', ''):
                sys.stderr.write("\033[2;32m[sys] Memory injected.\033[0m\n")
                sys.stderr.flush()
                print("\n### Relevant Past Discussion (Retrieved from Session Memory):")
                print(f"* **On {date_str} you asked**: \"{user_msg}\"\n  **Agent responded**: \"{assistant_msg.strip()}\"")
                break
            elif key in ('d', 'D'):
                sys.stderr.write("\033[2;31m[sys] Memory recall disabled. (Type /m to re-enable)\033[0m\n")
                sys.stderr.flush()
                sys.exit(3)
            elif key in ('\x1b[A', '\x1b[B'):
                current_idx = (current_idx + (1 if key == '\x1b[B' else -1) + num_opts) % num_opts
            else:
                sys.stderr.write("\033[2;31m[sys] Memory recall skipped.\033[0m\n")
                sys.stderr.flush()
                sys.exit(0)
    finally:
        sys.stderr.write("\033[?25h")
        sys.stderr.flush()


def tpm_reconcile(workspace: str) -> None:
    """Weaviate Engram Reconciliation Loop: Overwrites or inserts up-to-date facts in SQLite."""
    try:
        json_data = sys.stdin.read().strip()
        parsed = json.loads(json_data)
    except Exception:
        sys.exit(1)
    if not parsed or not isinstance(parsed, dict):
        sys.exit(0)
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    with closing(sqlite3.connect(db_path, timeout=10)) as conn:
        cur = conn.cursor()
        now = int(time.time())
        for k, v in parsed.items():
            k_clean = k.strip().lower()
            v_clean = str(v).strip()
            if not v_clean or v_clean.lower() in ("none", "null", "removed", "deleted"):
                cur.execute("DELETE FROM tpm_memories WHERE key = ?", (k_clean,))
            else:
                cur.execute("INSERT OR REPLACE INTO tpm_memories (key, value, timestamp) VALUES (?, ?, ?)", (k_clean, v_clean, now))
        conn.commit()


def tpm_get(workspace: str) -> None:
    """Reads compiled, reconciled facts from SQLite and outputs a structured Markdown block."""
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    if not os.path.exists(db_path):
        return
    try:
        with closing(sqlite3.connect(db_path, timeout=10)) as conn:
            cur = conn.cursor()
            cur.execute("SELECT key, value FROM tpm_memories ORDER BY key")
            rows = cur.fetchall()
            if not rows:
                return
            lines = ["### TEMPORAL PERSONALITY MEMORY (TPM):", "The following are compiled, up-to-date facts and style preferences about the user:"]
            for k, v in rows:
                lines.append(f"* **{k}**: {v}")
            print("\n".join(lines) + "\n")
    except Exception:
        pass


def tpm_clear(workspace: str) -> None:
    """Wipes all compiled facts from the tpm_memories table."""
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    if os.path.exists(db_path):
        with closing(sqlite3.connect(db_path, timeout=10)) as conn:
            cur = conn.cursor()
            cur.execute("DELETE FROM tpm_memories")
            conn.commit()


def get_tpm_count(workspace: str) -> None:
    """Outputs the count of active compiled facts in the database."""
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    if os.path.exists(db_path):
        try:
            with closing(sqlite3.connect(db_path, timeout=10)) as conn:
                cur = conn.cursor()
                cur.execute("SELECT COUNT(*) FROM tpm_memories")
                print(cur.fetchone()[0])
        except Exception:
            print(0)
    else:
        print(0)


if __name__ == "__main__":
    args = sys.argv[1:]
    if len(args) < 2: sys.exit(1)
    cmd, workspace_name = args[0], args[1]
    if cmd == "get-context":
        search_past_context(workspace_name, args[2] if len(args) > 2 else "")
    elif cmd == "tpm-reconcile":
        tpm_reconcile(workspace_name)
    elif cmd == "tpm-get":
        tpm_get(workspace_name)
    elif cmd == "tpm-clear":
        tpm_clear(workspace_name)
    elif cmd == "get-tpm-count":
        get_tpm_count(workspace_name)
